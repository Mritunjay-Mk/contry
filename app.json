{
  "expo": {
    "name": "Contry",
    "slug": "contry",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "contry",
    "icon": "./client/image/Logo.png",
    "splash": {
      "backgroundColor": "#22C55E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.example.contry",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.example.contry",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./client/image/Logo.png",
        "backgroundColor": "#22C55E"
      }
    },
    "plugins": [
      "expo-camera",
      "expo-image-picker"
    ]
  }
}
